#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

if [[ -f "${ROOT_DIR}/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "${ROOT_DIR}/.env"
  set +a
fi

FRONTEND_PORT="${FRONTEND_PORT:-8080}"
BACKEND_PORT="${BACKEND_PORT:-3001}"

usage() {
  cat <<USAGE
pipeline-builder command

Usage:
  pipeline-builder up            Start stack (docker compose up -d --build)
  pipeline-builder down          Stop stack
  pipeline-builder restart       Restart stack
  pipeline-builder logs          Tail logs
  pipeline-builder ps            Show service status
  pipeline-builder status        Check backend health and print URLs
  pipeline-builder help          Show this help
USAGE
}

require_docker() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "docker is required but not found in PATH." >&2
    exit 1
  fi
}

cmd="${1:-up}"

case "${cmd}" in
  up)
    require_docker
    (cd "${ROOT_DIR}" && docker compose up -d --build)
    echo "UI:      http://localhost:${FRONTEND_PORT}"
    echo "Backend: http://localhost:${BACKEND_PORT}/health"
    ;;
  down)
    require_docker
    (cd "${ROOT_DIR}" && docker compose down)
    ;;
  restart)
    require_docker
    (cd "${ROOT_DIR}" && docker compose down && docker compose up -d --build)
    echo "UI:      http://localhost:${FRONTEND_PORT}"
    echo "Backend: http://localhost:${BACKEND_PORT}/health"
    ;;
  logs)
    require_docker
    (cd "${ROOT_DIR}" && docker compose logs -f)
    ;;
  ps)
    require_docker
    (cd "${ROOT_DIR}" && docker compose ps)
    ;;
  status)
    require_docker
    (cd "${ROOT_DIR}" && docker compose ps)
    if command -v curl >/dev/null 2>&1; then
      echo ""
      if curl -fsS "http://localhost:${BACKEND_PORT}/health" >/dev/null; then
        echo "Backend health: OK"
      else
        echo "Backend health: FAILED"
      fi
    fi
    echo "UI:      http://localhost:${FRONTEND_PORT}"
    echo "Backend: http://localhost:${BACKEND_PORT}/health"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: ${cmd}" >&2
    echo ""
    usage
    exit 1
    ;;
esac
